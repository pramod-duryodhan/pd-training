#%RAML 1.0 Trait
usage: Adds required authentication headers to secured endpoints.
headers:
  client_id:
    type: string
    required: true
    maxLength: 100
    example: 55e863f1ec21467996cbf3687b04f132
  client_secret:
    type: string
    required: true
    maxLength: 100
    example: c8CVBBb90d594c739FD7E0Ac0475EBAc
  
  